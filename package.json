{
  "name": "eventferry",
  "version": "0.1.0",
  "private": true,
  "description": "Transactional outbox toolkit for Postgres + Kafka/Redpanda",
  "type": "module",
  "scripts": {
    "build": "pnpm -r --filter \"./packages/*\" run build",
    "test": "pnpm -r --filter \"./packages/*\" run test",
    "test:run": "pnpm -r --filter \"./packages/*\" run test:run",
    "test:integration": "pnpm --filter @eventferry/integration run test:integration",
    "typecheck": "pnpm -r --filter \"./packages/*\" run typecheck",
    "lint": "pnpm -r --filter \"./packages/*\" run lint",
    "clean": "pnpm -r exec rm -rf dist node_modules .turbo",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "pnpm build && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.10",
    "@types/node": "^22.10.2",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "packageManager": "pnpm@11.7.0",
  "engines": {
    "node": ">=18"
  },
  "license": "MIT"
}
