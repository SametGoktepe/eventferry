{
  "name": "@eventferry/core",
  "version": "3.3.1",
  "description": "DB- and broker-agnostic core for the transactional outbox pattern",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "CHANGELOG.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest",
    "test:run": "vitest run",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.test-d.json"
  },
  "keywords": [
    "outbox",
    "outbox-pattern",
    "transactional-outbox",
    "dual-write",
    "event-driven",
    "event-driven-architecture",
    "event-publishing",
    "event-sourcing",
    "cdc",
    "change-data-capture",
    "kafka",
    "redpanda",
    "microservices",
    "distributed-systems",
    "reliable-messaging",
    "at-least-once",
    "eventual-consistency",
    "nodejs",
    "typescript"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SametGoktepe/eventferry.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/SametGoktepe/eventferry/tree/main/packages/core#readme",
  "bugs": "https://github.com/SametGoktepe/eventferry/issues",
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
