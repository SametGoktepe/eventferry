{
  "name": "@eventferry/all",
  "version": "3.2.3",
  "description": "Meta-package: installs and re-exports all of eventferry (core + postgres + mysql + kafka + schema-registry)",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "CHANGELOG.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "outbox",
    "outbox-pattern",
    "transactional-outbox",
    "dual-write",
    "event-driven",
    "event-driven-architecture",
    "event-publishing",
    "cdc",
    "change-data-capture",
    "kafka",
    "redpanda",
    "postgres",
    "postgresql",
    "mysql",
    "mariadb",
    "schema-registry",
    "microservices",
    "distributed-systems",
    "reliable-messaging",
    "at-least-once",
    "nodejs",
    "typescript",
    "eventferry"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SametGoktepe/eventferry.git",
    "directory": "packages/all"
  },
  "homepage": "https://github.com/SametGoktepe/eventferry/tree/main/packages/all#readme",
  "bugs": "https://github.com/SametGoktepe/eventferry/issues",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@eventferry/core": "workspace:*",
    "@eventferry/postgres": "workspace:*",
    "@eventferry/mysql": "workspace:*",
    "@eventferry/kafka": "workspace:*",
    "@eventferry/schema-registry": "workspace:*"
  },
  "devDependencies": {
    "tsup": "^8.3.5",
    "typescript": "^5.7.2"
  }
}
